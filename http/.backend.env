# ================================
# HTTP Server Environment Variables
# ================================

# Server
PORT=3001
BASE_URL=http://localhost:3001

# CORS - allowed origins (comma separated for multiple)
CORS_ORIGIN=http://localhost:3000

# JWT (if auth is added later)
JWT_SECRET=your_jwt_secret_here

# Database (uncomment when needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/textchat
# MONGO_URI=mongodb://localhost:27017/textchat
# REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development
